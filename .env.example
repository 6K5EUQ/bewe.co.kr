# BEWE Web Server — environment variables
# Copy to .env and fill in values before starting

# HTTP server port
PORT=3000

# ── Mail / auth ──
# Email domain assigned to users (username@MAIL_DOMAIN)
MAIL_DOMAIN=bewe.co.kr
# Secret for signing session cookies — set a long random value; keep stable so
# sessions survive restarts.  e.g.  openssl rand -hex 32
SESSION_SECRET=
# Bootstrap admin (can approve signups). Created on first start if absent.
ADMIN_USER=
ADMIN_PASS=
# Shared secret for the Cloudflare Email Worker → /api/mail/inbound webhook.
# Must match the Worker's INBOUND_SECRET.  e.g.  openssl rand -hex 32
INBOUND_SECRET=
# Resend API key for outbound mail to external recipients. The MAIL_DOMAIN must
# be a verified sending domain in Resend (adds DKIM/SPF DNS records at Cloudflare).
# If unset, external send is stored in Sent but not actually delivered.
RESEND_API_KEY=

# Central relay server (BEWE binary protocol, port 7700)
RELAY_HOST=127.0.0.1
RELAY_PORT=7700

# OpenSky ADS-B API — aircraft overlay on globe (optional)
# Register at: https://opensky-network.org
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# auto_rx radiosonde decoder on DGS-2 over Tailscale (optional)
# Default points to DGS-2 Tailscale IP; override if network changes
SONDE_URL=http://100.126.69.82:5000
